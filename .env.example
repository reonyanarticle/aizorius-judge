# AIzorius Judge — 環境変数（すべて任意。未設定でもデフォルトで動く）

# Embeddingモデル（Sentence Transformers のモデル名）
# EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Embedding実行デバイス: mps（Apple Silicon）| cpu
# EMBEDDING_DEVICE=mps

# データディレクトリ（ChromaDB永続化・パース済みCRの置き場所）
# DATA_DIR=./data

# 外部評価（scripts/run_external_eval.py）を使う場合のみ必要
# GPT4_API_KEY=

# リランカーモデル（空にすると rerank なしの高速構成）
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# リランカーの入力上限とバッチ（メモリ依存。非力な環境では 512 / 4 に下げる）
# RERANKER_MAX_LENGTH=1024
# RERANKER_BATCH_SIZE=8
