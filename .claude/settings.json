{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/py-format.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-gate.sh\"",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv tree:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(mkdir:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "WebFetch(domain:scryfall.com)",
      "WebFetch(domain:api.scryfall.com)",
      "WebFetch(domain:gofastmcp.com)",
      "WebFetch(domain:docs.trychroma.com)",
      "WebFetch(domain:modelcontextprotocol.io)",
      "WebFetch(domain:media.wizards.com)",
      "WebFetch(domain:magic.wizards.com)",
      "WebFetch(domain:mtg-jp.com)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean:*)"
    ]
  },
  "enabledPlugins": {
    "mcp-server-dev@claude-plugins-official": true
  }
}
